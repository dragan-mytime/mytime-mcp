{
  "name": "mytime-bi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MY:TIME competitive-intelligence platform — ingestion + remote MCP server over Supabase Postgres.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rimraf dist *.tsbuildinfo",
    "lint": "biome check .",
    "format": "biome format --write .",
    "validate:targets": "node shared/dist/scripts/validate-targets.js config/targets.json",
    "db:generate": "pnpm --filter @mytime/db generate",
    "db:migrate": "pnpm --filter @mytime/db migrate",
    "db:seed": "node db/dist/seed.js",
    "ingest": "node ingestion/dist/index.js",
    "ingest:status": "node ingestion/dist/status.js",
    "validate": "node ingestion/dist/validation/run.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
