# ─────────────────────────────────────────────────────────────────────────────
# MY:TIME BI — environment variables
# Copy to `.env` (gitignored) and fill in. Every variable the system reads at
# runtime is listed here. Missing required vars fail fast, naming the variable.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database: Supabase managed Postgres (Frankfurt / EU) ─────────────────────
# Ingestion uses a write-capable role; migrations use this too.
DATABASE_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres
# Least-privilege read-mostly role for the MCP server (Phase 4+). Falls back to
# DATABASE_URL if unset, but a dedicated read-only role is strongly recommended.
DATABASE_URL_READONLY=postgresql://mcp_readonly:password@db.<project-ref>.supabase.co:5432/postgres
# TLS to Supabase. Pin the CA for full verification (recommended in production):
#   DATABASE_CA_CERT=/path/to/supabase-ca.crt
# Or, to encrypt without verifying the self-signed chain:
#   DATABASE_SSL_NO_VERIFY=true

# ── Crawlers (Phase 1/3) ─────────────────────────────────────────────────────
APIFY_TOKEN=
# May be added after Phase 1 profiling decides which sites need it.
FIRECRAWL_API_KEY=

# ── MY:TIME own-brand product feed (Adform XML) ──────────────────────────────
# Full URL INCLUDING the seckey/user/pass credentials — never commit this.
# config/targets.json references it by name (feed_env), never the secret itself.
MYTIME_FEED_URL=https://www.mytime.mk/webservis/externalsite/mytime/adform_xml.php?seckey=REDACTED&user=REDACTED&pass=REDACTED

# ── Own-brand social: official APIs (Phase 3) ────────────────────────────────
# Meta Graph API for MY:TIME's own IG/FB accounts.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Google APIs for MY:TIME's own properties (e.g. YouTube/Business if used).
GOOGLE_API_CLIENT_ID=
GOOGLE_API_CLIENT_SECRET=

# ── MCP server OAuth 2.1 — upstream login = Google (Phase 5) ─────────────────
# NOTE: these are the OAuth *login* credentials, distinct from GOOGLE_API_* above.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public origin the MCP server is served from (used in OAuth metadata).
MCP_PUBLIC_URL=https://mcp.my.mk
# Domain gate (Layer 1): only verified emails on this domain may authenticate.
ALLOWED_EMAIL_DOMAIN=mytime.mk

# ── MCP server runtime ───────────────────────────────────────────────────────
MCP_PORT=8080
LOG_LEVEL=info
NODE_ENV=development
