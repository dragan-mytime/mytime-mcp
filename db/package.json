    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@mytime/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
